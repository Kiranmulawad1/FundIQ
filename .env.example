# ============================================================
# FundIQ — environment variables
# Copy this file to .env and fill in real values.
# Never commit .env to git.
# ============================================================

# ---------- App ----------
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
APP_PORT=8000

# ---------- Background jobs / heavy models ----------
# SCHEDULER_ENABLED: turn on the APScheduler cron jobs (scrape every night).
# Always on in staging/production; opt-in here for dev.
SCHEDULER_ENABLED=false          # true to enable in dev

# WARM_MODELS: pre-load the BGE reranker (~2.3GB) and the e5-large embedder
# at startup so the first /agents/recommend request isn't a 50s cold-load.
# Adds ~30-90s to boot. Always on in staging/production; opt-in here for dev.
WARM_MODELS=false                # true to pre-load BGE + e5 on startup

# ---------- LLM providers ----------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...     # optional, used for Claude-based agents

# ---------- Embeddings ----------
# multilingual-e5-large runs locally via sentence-transformers (no key needed).
# HF_TOKEN is only required for gated models or HF Inference API calls.
HF_TOKEN=hf_...

# ---------- Observability ----------
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=fundiq
LANGSMITH_TRACING=true
LOGFIRE_TOKEN=                   # Pydantic Logfire (optional)

# ---------- Database — Neon Postgres (with pgvector) ----------
DATABASE_URL=postgresql+psycopg://user:password@host/fundiq?sslmode=require

# ---------- Knowledge graph — Neo4j AuraDB ----------
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ---------- Cache / queues — Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- Auth — Clerk ----------
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ---------- Scheduler — Hatchet ----------
HATCHET_CLIENT_TOKEN=

# ---------- Frontend (Vite) ----------
VITE_API_URL=http://localhost:8000
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
